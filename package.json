{
  "name": "medicamentos-multifamiliar",
  "version": "0.1.0",
  "private": true,
  "description": "Gestión de Medicamentos Multifamiliar - utilidades locales",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "healthcheck": "node healthcheck.js",
    "test-system": "node test-system.js",
    "cap:sync": "npx cap sync",
    "ci:ios": "npm ci && node scripts/fix-ios-spm-package.js && npx cap sync ios && node scripts/fix-ios-spm-package.js",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:verify": "node verify-capacitor.js",
    "cap:build:aab": "cd android && gradlew.bat bundleRelease",
    "android:aab": "powershell -ExecutionPolicy Bypass -File ./build-aab.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-progress": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "pg": "^8.13.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "autoprefixer": "^10.4.24",
    "pdfkit": "^0.17.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
